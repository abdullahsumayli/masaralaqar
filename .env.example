# Resend (Email)
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=noreply@masaralaqar.com

# Upstash (Rate Limiting)
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Redis (BullMQ Message Queue)
# Standard Redis instance — NOT the Upstash REST API above.
# Supports REDIS_URL or REDIS_URI (both work).
REDIS_URL=redis://default:password@localhost:6379
# REDIS_URI also accepted (alias for REDIS_URL)
# Or split config (used if REDIS_URL/REDIS_URI are empty):
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=

# Sentry (Error Tracking)
SENTRY_DSN=https://your-sentry-dsn@o123.ingest.sentry.io/456
SENTRY_ENVIRONMENT=production
