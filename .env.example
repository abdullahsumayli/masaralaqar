# MCP / CI Tokens
GITHUB_PERSONAL_ACCESS_TOKEN=
SUPABASE_ACCESS_TOKEN=
VERCEL_TOKEN=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# OpenAI API (GPT-4o-mini)
OPENAI_API_KEY=sk-proj-your-api-key-here

# WAHA — WhatsApp HTTP API (dashboard + /api/webhook/whatsapp + /api/mq/waha/*)
# Header: X-Api-Key
WAHA_API_URL=https://your-waha-host:3000
WAHA_API_KEY=
# Optional: fixed session name for /api/mq/waha/* test routes (default mq-test)
WAHA_MQ_SESSION=mq-test
MQ_WAHA_INTERNAL_KEY=

# Webhook Secret — generate a strong random string (e.g. openssl rand -hex 32)
WEBHOOK_SECRET=your-strong-random-secret-here

# Masar AI Server
NEXT_PUBLIC_MASAR_AI_API_URL=http://localhost:3001

# App
PORT=3000
NEXT_PUBLIC_URL=https://masaralaqar.com

# Admin: قائمة بريدات المسؤولين (مفصولة بفاصلة) — للوصول إلى /admin/login
NEXT_PUBLIC_ADMIN_EMAILS=sumayliabdullah@gmail.com

# Moyasar Payment Gateway
MOYASAR_API_KEY=sk_test_your-moyasar-secret-key
MOYASAR_PUBLISHABLE_KEY=pk_test_your-moyasar-publishable-key
MOYASAR_CALLBACK_URL=https://masaralaqar.com/api/payments/callback

# Resend (Email)
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=noreply@masaralaqar.com

# ── Redis (BullMQ Queue + AI Cache) ──────────────────────────
# Upstash Redis (recommended — works from Vercel + EasyPanel):
#   1. Create a database at https://console.upstash.com
#   2. Copy the "Redis URL" (rediss:// format, NOT the REST URL)
#   3. Paste it as REDIS_URL below
# Format: rediss://default:TOKEN@ENDPOINT.upstash.io:6379
REDIS_URL=rediss://default:YOUR_TOKEN@YOUR_ENDPOINT.upstash.io:6379
# REDIS_URI also accepted (alias)
# Or self-hosted: redis://default:password@host:6379/0
# Or split config (used if REDIS_URL/REDIS_URI are empty):
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=

# Upstash REST API (used for rate limiting only, separate from BullMQ)
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── Worker Configuration ─────────────────────────────────────
# Run locally:   npm run worker
# Run in Docker:  docker build -f Dockerfile.worker -t masaralaqar-worker .
#                 docker run --env-file .env -p 3001:3001 masaralaqar-worker
# Coolify:        Create Application → Dockerfile Path: Dockerfile.worker
#
# Scale to multiple workers (each needs a unique WORKER_ID):
#   WORKER_ID=w1 npm run worker:prod &
#   WORKER_ID=w2 npm run worker:prod &
WORKER_CONCURRENCY=5
WORKER_RATE_MAX=10
# WORKER_ID=worker-1  (auto-generated from PID if not set)
# HEALTH_PORT=3001     (HTTP health check port for container orchestrators)

# Sentry (Error Tracking)
SENTRY_DSN=https://your-sentry-dsn@o123.ingest.sentry.io/456
SENTRY_ENVIRONMENT=production
