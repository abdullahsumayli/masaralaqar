# ── Redis (BullMQ Queue + AI Cache) ──────────────────────────
# Upstash Redis (recommended — works from Vercel + EasyPanel):
#   1. Create a database at https://console.upstash.com
#   2. Copy the "Redis URL" (rediss:// format, NOT the REST URL)
#   3. Paste it as REDIS_URL below
# Format: rediss://default:TOKEN@ENDPOINT.upstash.io:6379
REDIS_URL=rediss://default:YOUR_TOKEN@YOUR_ENDPOINT.upstash.io:6379
# REDIS_URI also accepted (alias)
# Or self-hosted: redis://default:password@host:6379/0
# Or split config (used if REDIS_URL/REDIS_URI are empty):
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=

# Upstash REST API (used for rate limiting only, separate from BullMQ)
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── Worker Configuration ─────────────────────────────────────
# Run multiple workers: WORKER_ID=w1 npm run worker & WORKER_ID=w2 npm run worker
WORKER_CONCURRENCY=5
WORKER_RATE_MAX=10
# WORKER_ID=w1  (auto-generated from PID if not set)

# Sentry (Error Tracking)
SENTRY_DSN=https://your-sentry-dsn@o123.ingest.sentry.io/456
SENTRY_ENVIRONMENT=production
